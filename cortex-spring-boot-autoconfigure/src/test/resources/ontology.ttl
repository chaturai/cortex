@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

@prefix : <cortex://ontology/> .
@prefix cortex: <cortex://> .

:Task a owl:Class .

:Agent a owl:Class .

:assignedTo a owl:ObjectProperty ;
    rdfs:domain :Task ;
    rdfs:range :Agent .
