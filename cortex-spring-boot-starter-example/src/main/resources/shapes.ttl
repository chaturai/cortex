@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .

@prefix : <cortex://ontology/> .
@prefix s: <cortex://shapes/> .

# Common constraints for every assertion node
s:AssertionShape a sh:NodeShape ;
    # Reach every assertion node: anything typed, and anything using a known property
    sh:targetSubjectsOf rdf:type ;
    sh:targetSubjectsOf :hasCondition ;

    sh:nodeKind sh:IRI ;
    sh:pattern "^cortex://[^/?#]+$" ;
    sh:message "assertions must be cortex://{name} IRIs without sub-paths" ;

    # Reject unknown classes; every assertion must be typed
    sh:property [
        sh:path rdf:type ;
        sh:minCount 1 ;
        sh:in ( :Rule :Condition ) ;
        sh:message "unknown class: only cortex://ontology/ classes are allowed" ;
    ] ;

    # Every assertion must carry a label and a comment
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:message "every assertion must have an rdfs:label" ;
    ] ;
    sh:property [
        sh:path rdfs:comment ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:message "every assertion must have an rdfs:comment" ;
    ] .

s:RuleShape a sh:NodeShape ;
    sh:targetClass :Rule ;

    # Close the shape: reject any properties not declared below
    sh:closed true ;
    sh:property [ sh:path rdf:type ] ;
    sh:property [ sh:path rdfs:label ] ;
    sh:property [ sh:path rdfs:comment ] ;

    sh:property [
        sh:path :hasCondition ;
        sh:class :Condition ;
        sh:minCount 1 ;
        sh:message "a Rule must have at least one Condition" ;
    ] .

s:ConditionShape a sh:NodeShape ;
    sh:targetClass :Condition ;

    # Conditions carry nothing beyond type, label, and comment
    sh:closed true ;
    sh:property [ sh:path rdf:type ] ;
    sh:property [ sh:path rdfs:label ] ;
    sh:property [ sh:path rdfs:comment ] .
