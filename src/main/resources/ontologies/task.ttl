@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

@prefix : <cortex://ontology/> .

:Task a owl:Class ;
    rdfs:label "Task" .

:CriticalTask a owl:Class ;
    rdfs:subClassOf :Task ;
    rdfs:label "Critical Task" .

:dependsOn a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain :Task ;
    rdfs:range :Task ;
    rdfs:label "depends on" .

:assignedTo a owl:ObjectProperty ;
    rdfs:domain :Task ;
    rdfs:range :Agent ;
    rdfs:label "assigned to" .
