@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

@prefix g: <cortex://graph/> .
@prefix o: <cortex://ontologies/> .
@prefix i: <cortex://instances/> .

o:Task a owl:Class .

o:Agent a owl:Class .

o:assignedTo a owl:ObjectProperty ;
    rdfs:domain o:Task ;
    rdfs:range o:Agent .

