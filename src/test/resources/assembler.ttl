@prefix ja: <http://jena.hpl.hp.com/2005/11/Assembler#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tdb2: <http://jena.apache.org/2016/tdb#> .
@prefix text: <http://jena.apache.org/text#> .

@prefix : <cortex://> .
@prefix graph: <cortex://graph/> .

# Fixes AmbiguousSpecificTypeException: cannot find a most specific type for :instances, which has as possibilities: tdb2:GraphTDB2 ja:Model.
tdb2:GraphTDB2 rdfs:subClassOf ja:Model .

# Attach this to any graph that needs to be persisted
:tdbDataset a tdb2:DatasetTDB ;
    tdb2:location ".cortex/data" ;
    tdb2:unionDefaultGraph true .

# Load static ontologies
:ontologies a ja:MemoryModel ;
    ja:content [ ja:externalContent <file:ontologies/cortex.ttl> ] .

# Define a graph for persistent instances
:instances a tdb2:GraphTDB2 ;
    tdb2:dataset :tdbDataset .

# Inferences should not be persisted
:inferences a ja:InfModel ;
    ja:baseModel :instances ;
    ja:reasoner :reasoner .

# Load static rules
:reasoner a ja:ReasonerFactory ;
    ja:reasonerURL <http://jena.hpl.hp.com/2003/GenericRuleReasoner> ;
    ja:rulesFrom <file:rules/cortex.rules> ;
    ja:schema :ontologies .

# Define the hybrid dataset
:dataset a ja:RDFDataset ;
    ja:defaultGraph :ontologies ;
    ja:namedGraph [ ja:graphName graph:instances ; ja:graph :instances ] ;
    ja:namedGraph [ ja:graphName graph:inferences ; ja:graph :inferences ] .

# Add jena-text layer on top
:textDataset a text:TextDataset ;
    text:dataset :dataset ;
    text:index :index .

# Configure Lucene
:index a text:TextIndexLucene ;
    text:directory <file:.cortex/index> ;
    text:entityMap :entityMap ;
    text:storeValues true ;
    text:analyzer [ a text:StandardAnalyzer ] ;
    text:queryAnalyzer [ a text:KeywordAnalyzer ] ;
    text:queryParser text:AnalyzingQueryParser .

# Configure fields to index
:entityMap a text:EntityMap ;
    text:entityField "uri" ;
    text:defaultField "text" ;
    text:uidField "uid" ;
    text:map (
        [ text:field "text" ; text:predicate rdfs:label ; ]
        [ text:field "comment" ; text:predicate rdfs:comment ; ]
    ) .
